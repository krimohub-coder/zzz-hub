-- CLEAN OLD GUI
local player = game.Players.LocalPlayer
local pg = player:WaitForChild("PlayerGui")

if pg:FindFirstChild("zzz_hub") then
	pg.zzz_hub:Destroy()
end

print("GUI LOADED")

-- SERVICES
local UIS = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")

-- GUI
local gui = Instance.new("ScreenGui", pg)
gui.Name = "zzz_hub"
gui.ResetOnSpawn = false

-- COLORS
local BG = Color3.fromRGB(8,8,12)
local CARD = Color3.fromRGB(18,18,24)
local ACCENT = Color3.fromRGB(0,170,255)

-- MAIN FRAME
local main = Instance.new("Frame", gui)
main.Size = UDim2.new(0, 220, 0, 320)
main.Position = UDim2.new(0.1, 0, 0.2, 0)
main.BackgroundColor3 = BG
main.BorderSizePixel = 0
Instance.new("UICorner", main).CornerRadius = UDim.new(0,10)

-- TOP BAR
local title = Instance.new("TextLabel", main)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "zzz hub"
title.TextColor3 = ACCENT
title.Font = Enum.Font.GothamBold
title.TextSize = 16

-- DRAG SYSTEM
local dragging = false
local dragInput, dragStart, startPos

title.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = main.Position
		
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

title.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement then
		dragInput = input
	end
end)

UIS.InputChanged:Connect(function(input)
	if input == dragInput and dragging then
		local delta = input.Position - dragStart
		main.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end
end)

-- LAYOUT
local layout = Instance.new("UIListLayout", main)
layout.Padding = UDim.new(0,5)
layout.SortOrder = Enum.SortOrder.LayoutOrder

-- SECTION
local function section(text)
	local l = Instance.new("TextLabel", main)
	l.Size = UDim2.new(1,-10,0,18)
	l.BackgroundTransparency = 1
	l.Text = text
	l.TextColor3 = ACCENT
	l.Font = Enum.Font.GothamBold
	l.TextSize = 11
	l.TextXAlignment = Enum.TextXAlignment.Left
end

-- TOGGLE
local function toggle(name)
	local frame = Instance.new("Frame", main)
	frame.Size = UDim2.new(1,-10,0,26)
	frame.BackgroundColor3 = CARD
	frame.BorderSizePixel = 0
	Instance.new("UICorner", frame).CornerRadius = UDim.new(0,6)

	local text = Instance.new("TextLabel", frame)
	text.Size = UDim2.new(0.65,0,1,0)
	text.BackgroundTransparency = 1
	text.Text = name
	text.TextColor3 = Color3.fromRGB(255,255,255)
	text.Font = Enum.Font.Gotham
	text.TextSize = 11
	text.TextXAlignment = Enum.TextXAlignment.Left

	local btn = Instance.new("Frame", frame)
	btn.Size = UDim2.new(0,36,0,16)
	btn.Position = UDim2.new(1,-42,0.5,-8)
	btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
	Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)

	local knob = Instance.new("Frame", btn)
	knob.Size = UDim2.new(0,14,0,14)
	knob.Position = UDim2.new(0,1,0.5,-7)
	knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

	local state = false

	frame.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			state = not state
			
			TweenService:Create(btn, TweenInfo.new(0.2), {
				BackgroundColor3 = state and ACCENT or Color3.fromRGB(50,50,50)
			}):Play()
			
			TweenService:Create(knob, TweenInfo.new(0.2), {
				Position = state and UDim2.new(1,-15,0.5,-7) or UDim2.new(0,1,0.5,-7)
			}):Play()
		end
	end)
end

-- SLIDER (DISPLAY ONLY)
local function slider(name, value)
	local f = Instance.new("Frame", main)
	f.Size = UDim2.new(1,-10,0,28)
	f.BackgroundColor3 = CARD
	Instance.new("UICorner", f).CornerRadius = UDim.new(0,6)

	local t = Instance.new("TextLabel", f)
	t.Size = UDim2.new(1,0,1,0)
	t.BackgroundTransparency = 1
	t.Text = name.."  "..value
	t.TextColor3 = Color3.fromRGB(255,255,255)
	t.Font = Enum.Font.Gotham
	t.TextSize = 11
end

-- BUILD UI
section("SPEED")
slider("Normal Speed", 19)
slider("Carry Speed", 29)
toggle("Speed Toggle")

section("COMBAT")
toggle("Auto Batt")

section("MECHANICS")
toggle("Insta Grab")
toggle("Infinite Jump")
toggle("Anti Ragdoll")
toggle("FPS Boost")
toggle("Medusa Counter")
